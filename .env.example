# ── Vision-Language Model settings ───────────────────────────────────────────
# Open CLIP model architecture (e.g. ViT-B-32, ViT-L-14, ViT-H-14)
OPENCLIP_MODEL=ViT-L-14

# Open CLIP pretrained weights tag (e.g. laion2b_s32b_b82k, openai)
OPENCLIP_PRETRAINED=laion2b_s32b_b82k

# ── Whisper ASR settings ──────────────────────────────────────────────────────
# faster-whisper model size: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=large-v3

# ── Anthropic Claude API ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
# Python logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
